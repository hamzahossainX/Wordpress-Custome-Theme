<svg width="600" height="600" xmlns="http://www.w3.org/2000/svg">
  <!-- Background -->
  <rect width="600" height="600" fill="#F8F8F8"/>
  
  <!-- Watch Circle -->
  <circle cx="300" cy="300" r="150" fill="#FFFFFF" stroke="#242424" stroke-width="8"/>
  
  <!-- Watch Face -->
  <circle cx="300" cy="300" r="140" fill="#FFFFFF" stroke="#CCCCCC" stroke-width="2"/>
  
  <!-- Hour Markers -->
  <line x1="300" y1="170" x2="300" y2="185" stroke="#242424" stroke-width="4"/>
  <line x1="300" y1="415" x2="300" y2="430" stroke="#242424" stroke-width="4"/>
  <line x1="170" y1="300" x2="185" y2="300" stroke="#242424" stroke-width="4"/>
  <line x1="415" y1="300" x2="430" y2="300" stroke="#242424" stroke-width="4"/>
  
  <!-- Hour Hand -->
  <line x1="300" y1="300" x2="300" y2="240" stroke="#242424" stroke-width="6" stroke-linecap="round"/>
  
  <!-- Minute Hand -->
  <line x1="300" y1="300" x2="350" y2="300" stroke="#242424" stroke-width="4" stroke-linecap="round"/>
  
  <!-- Center Dot -->
  <circle cx="300" cy="300" r="8" fill="#000000"/>
  
  <!-- Watch Band -->
  <rect x="270" y="450" width="60" height="150" fill="#242424" rx="5"/>
  <rect x="270" y="0" width="60" height="150" fill="#242424" rx="5"/>
  
  <!-- Text -->
  <text x="300" y="520" font-family="Arial, sans-serif" font-size="24" fill="#777777" text-anchor="middle" font-weight="300">Luxury Watch</text>
</svg>
