   RESPONSIVE BREAKPOINTS
======================================== */

/* Tablet: 2 Columns 
@media screen and (max-width: 1024px) {
    .category-grid-section .container .category-grid,
    .category-grid-section .category-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
    }
    
    .category-grid-section .category-banner-item {
        height: 240px;
        min-height: 240px;
    }
}

/* Mobile: 1 Column 
@media screen and (max-width: 767px) {
    .category-grid-section {
        padding: 30px 0;
    }
    
    .category-grid-section .container .category-grid,
    .category-grid-section .category-grid {
        grid-template-columns: 1fr;
        gap: 15px;
    }
    
    .category-grid-section .category-banner-item {
        height: 220px;
        min-height: 220px;
    }
    
    .category-grid-section .banner-content {
        padding: 20px;
    }
    
    .category-grid-section .banner-title {
        font-size: 18px;
    }
}
