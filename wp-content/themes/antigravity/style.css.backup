/* ========================================
   CATEGORY BANNER SECTION - FINAL COMPREHENSIVE FIX
   WoodMart Minimalism Design Replication
   Wide Rectangle "Credit Card" Layout
======================================== */

/* RESET: Clear all conflicting styles 
.category-grid-section * {
    box-sizing: border-box;
}

/* CONTAINER: Full-width wrapper with constraints 
.category-grid-section {
    width: 100%;
    padding: 50px 0;
    background-color: #FFFFFF;
}

/* GRID WRAPPER: Force 3-column layout 
.category-grid-section .container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 15px;
}

.category-grid-section .container .category-grid,
.category-grid-section .category-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    width: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
}

/* CATEGORY BANNER ITEM: Wide Rectangle Shape 
.category-grid-section .category-banner-item {
    /* Dimensions: Credit Card Aspect Ratio 
    width: 100%;
    height: 260px;
    min-height: 260px;
    
    /* Layout 
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    
    /* Background 
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    background-color: #f5f5f5;
    
    /* Reset conflicting properties 
    margin: 0;
    padding: 0;
    float: none;
    flex: none;
    
    /* Polish 
    border-radius: 4px;
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.category-grid-section .category-banner-item:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
}

/* BANNER OVERLAY: Dark gradient for text readability 
.category-grid-section .banner-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, rgba(0, 0, 0, 0.5) 0%, rgba(0, 0, 0, 0.2) 100%);
    z-index: 1;
}
/* BANNER CONTENT: Text positioned left, vertically centered 
.category-grid-section .banner-content {
    position: relative;
    z-index: 2;
    padding: 30px;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
}

/* Typography 
.category-grid-section .banner-subtitle {
    font-size: 11px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    color: rgba(255, 255, 255, 0.85);
    margin: 0 0 8px 0;
}

.category-grid-section .banner-title {
    font-size: 22px;
    font-weight: 700;
    color: #FFFFFF;
    margin: 0 0 18px 0;
    line-height: 1.3;
}

.category-grid-section .banner-button {
    display: inline-block;
    padding: 10px 24px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    color: #FFFFFF;
    background-color: transparent;
    border: 2px solid #FFFFFF;
    border-radius: 2px;
    transition: all 0.3s ease;
    text-decoration: none;
}

.category-grid-section .banner-button:hover {
    background-color: #FFFFFF;
    color: #000000;
}

